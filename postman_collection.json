            "value": "Token {{auth_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v2/books/1/",
          "host": ["{{base_url}}"],
          "path": ["api", "v2", "books", "1", ""]
        }
      }
    },
